{
  "manifest_version": 3,
  "name": "OpenInfinity",
  "version": "1.0.0",
  "description": "A secure, transparent, and high-performance new tab browser extension. Open source and privacy-first.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "添加到 OpenInfinity"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "optional_permissions": [
    "tabs",
    "contextMenus",
    "activeTab",
    "identity",
    "identity.email",
    "notifications",
    "bookmarks",
    "history",
    "management"
  ],
  "commands": {
    "add-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "添加当前页面到 OpenInfinity"
    }
  },
  "host_permissions": [],
  "optional_host_permissions": [
    "https://api.unsplash.com/*",
    "https://images.unsplash.com/*",
    "https://source.unsplash.com/*",
    "https://api.pexels.com/*",
    "https://images.pexels.com/*",
    "https://peapix.com/*",
    "https://pixabay.com/*",
    "https://www.google.com/*",
    "https://icons.duckduckgo.com/*",
    "https://api.open-meteo.com/*",
    "https://devapi.qweather.com/*",
    "https://*.qweatherapi.com/*",
    "https://api.openweathermap.org/*",
    "https://*.gstatic.com/*",
    "https://api.bigdatacloud.net/*",
    "https://www.googleapis.com/*",
    "https://wallhaven.cc/*",
    "https://w.wallhaven.cc/*",
    "https://ipapi.co/*",
    "https://nominatim.openstreetmap.org/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; object-src 'self'; connect-src 'self' https://api.unsplash.com https://api.pexels.com https://api.open-meteo.com https://devapi.qweather.com https://*.qweatherapi.com https://api.openweathermap.org https://api.bigdatacloud.net https://www.googleapis.com https://nominatim.openstreetmap.org https://ipapi.co https://wallhaven.cc https://w.wallhaven.cc; img-src 'self' data: blob: https:"
  }
}
