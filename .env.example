# Unsplash API Configuration
# Get your keys at: https://unsplash.com/oauth/applications
VITE_UNSPLASH_ACCESS_KEY=your-access-key-here
VITE_UNSPLASH_SECRET_KEY=your-secret-key-here
VITE_UNSPLASH_APP_ID=your-app-id-here

# OpenWeatherMap API Configuration (Optional - for weather fallback)
# Get your free key at: https://openweathermap.org/api
# Note: Free tier uses Current Weather + 5 Day Forecast APIs
VITE_OPENWEATHER_API_KEY=your-openweather-api-key-here

# Pexels API Configuration
# Get your key at: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your-pexels-api-key-here

# Wallhaven API Configuration (Optional - only needed for NSFW content)
# Get your key at: https://wallhaven.cc/settings/account
# VITE_WALLHAVEN_API_KEY=your-wallhaven-api-key-here

# QWeather (和风天气) API Configuration (Optional - recommended for China region)
# Get your credentials at: https://console.qweather.com/
# Documentation: https://dev.qweather.com/docs/configuration/authentication/#json-web-token
VITE_QWEATHER_PROJECT_ID=your-project-id-here
VITE_QWEATHER_CREDENTIAL_ID=your-credential-id-here
VITE_QWEATHER_PRIVATE_KEY=your-ed25519-private-key-base64-here

# Feature Flags
VITE_DEFAULT_WALLPAPER_SOURCE=unsplash

# Supabase (Phase 3)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
