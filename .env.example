# OpenInfinity Environment Variables
# Copy this file to .env and fill in your API keys

# ==================== Wallpaper APIs ====================

# Unsplash API
# Get your key from: https://unsplash.com/developers
# Free tier: 50 requests/hour (Demo), 5000 requests/hour (Production)
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels API
# Get your key from: https://www.pexels.com/api/
# Free tier: 200 requests/hour
VITE_PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API (Optional)
# Get your key from: https://pixabay.com/api/docs/
# Free tier: 100 requests/minute
VITE_PIXABAY_API_KEY=your_pixabay_api_key_here

# ==================== Notes ====================
#
# IMPORTANT: Never commit the actual .env file to Git!
# This .env.example is for reference only.
#
# To use:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your API keys
# 3. Restart the dev server: npm run dev
#
